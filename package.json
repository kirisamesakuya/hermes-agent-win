{
  "name": "hermes-windows-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop shell for Hermes Agent WebUI.",
  "main": "dist/desktop/src/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:desktop": "npm run build && node dist/desktop/src/smoke.js",
    "sync:vendor": "powershell -ExecutionPolicy Bypass -File scripts/sync-vendor.ps1"
  },
  "keywords": [
    "hermes",
    "electron",
    "windows"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^37.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
